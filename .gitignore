# ============================================================================
# AI-Rulez - Generated Files (DO NOT COMMIT)
# ============================================================================
# The source of truth is the .ai-rulez/ directory.
# All tool-specific outputs are generated and should be ignored.

# Directories created by ai-rulez generate
.cursor/
.windsurf/
.claude/
.opencode/
.gemini/
.continue/
.codex/
.agents/

# Root-level generated files
AGENTS.md
CLAUDE.md
GEMINI.md
.github/copilot-instructions.md

# AI-Rulez internal cache (keep the config itself versioned)
.ai-rulez/cache/
.ai-rulez/temp/

