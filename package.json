{
  "name": "ai-governed-rails8-nextjs16-ts-boilerplate",
  "version": "1.0.0",
  "private": true,
  "description": "Boilerplate Rails API and Next.js app",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"rails,frontend\" -c \"yellow,magenta\" \"pnpm --filter backend-api dev\" \"pnpm --filter frontend-web dev\"",
    "test": "concurrently -n \"backend,frontend\" -c \"yellow,magenta\" \"pnpm --filter backend-api test\" \"pnpm --filter frontend-web test\"",
    "lint": "concurrently -n \"backend,frontend\" -c \"yellow,magenta\" \"pnpm --filter backend-api lint\" \"pnpm --filter frontend-web lint\"",
    "build": "pnpm --filter backend-api generate:openapi && pnpm --filter frontend-web generate:api && pnpm --filter frontend-web build",
    "generate:api": "pnpm --filter backend-api generate:openapi && pnpm --filter frontend-web generate:api",
    "backend:dev": "pnpm --filter backend-api dev",
    "backend:console": "pnpm --filter backend-api console",
    "backend:migrate": "pnpm --filter backend-api migrate",
    "backend:rollback": "pnpm --filter backend-api rollback",
    "backend:seed": "pnpm --filter backend-api seed",
    "backend:reset": "pnpm --filter backend-api reset",
    "backend:test": "pnpm --filter backend-api test",
    "backend:rubocop": "pnpm --filter backend-api rubocop",
    "backend:rubocop:autocorrect": "pnpm --filter backend-api rubocop:autocorrect",
    "backend:generate:openapi": "pnpm --filter backend-api generate:openapi",
    "frontend:dev": "pnpm --filter frontend-web dev",
    "frontend:build": "pnpm --filter frontend-web build",
    "frontend:start": "pnpm --filter frontend-web start",
    "frontend:lint": "pnpm --filter frontend-web lint",
    "frontend:typecheck": "pnpm --filter frontend-web typecheck",
    "frontend:test": "pnpm --filter frontend-web test",
    "frontend:test:ui": "pnpm --filter frontend-web test:ui",
    "frontend:test:e2e": "pnpm --filter frontend-web test:e2e",
    "frontend:format": "pnpm --filter frontend-web format",
    "frontend:generate:api": "pnpm --filter frontend-web generate:api",
    "rules:init": "ai-rulez init 'AI Governed Rails 8 Next 16 TS Boilerplate'",
    "rules:generate": "./scripts/refresh-ai-rules.sh",
    "rules:watch": "tsx scripts/watch-rules.ts",
    "strip-timestamps": "node scripts/strip-timestamps.js",
    "workflows:sync": "./scripts/sync-windsurf-workflows.sh",
    "opencode:sync": "./scripts/sync-opencode.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^22.19.17",
    "ai-rulez": "^3.11.3",
    "concurrently": "^9.1.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "lint-staged": {
    "*.rb": [
      "pnpm --filter backend-api rubocop:autocorrect"
    ],
    "public/api-docs/**/*.json": [
      "pnpm --filter backend-api validate:openapi"
    ]
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0"
  }
}
